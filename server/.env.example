# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/solved-financial?retryWrites=true&w=majority

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── CORS Origins (your production domains) ───────────────────────────────────
CLIENT_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

# ─── AWS S3 (for image uploads) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_NAME=imperial-ventures-assets
AWS_REGION=eu-north-1

# ─── Email (Nodemailer SMTP — Gmail or AWS SES etc.) ──────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM overrides the visible "From" address when EMAIL_USER is an SMTP
# login (e.g. an AWS SES IAM access key) rather than a real mailbox.
EMAIL_FROM=no-reply@yourdomain.com
ADMIN_EMAIL=admin@solvedfinancial.com
